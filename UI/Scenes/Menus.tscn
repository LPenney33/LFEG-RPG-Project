[sub_resource type="GDScript" id="GDScript_ymnku"]
script/source = "extends Button

# References to the QuitConfirm popup and MainMenu
@onready var quitConfirmMenu = get_node(\"/root/FullUI/MenuSystem/Specific/QuitConfirm\")
@onready var mainMenuControl = get_node(\"/root/FullUI/MenuSystem/MainMenu\")

# Show Quit Confirm Menu When Button is clicked

func _on_pressed():
	quitConfirmMenu.visible = true
	mainMenuControl.visible = false

func _on_cancel_pressed():
	quitConfirmMenu.visible = false
	mainMenuControl.visible = true


func _on_quit_pressed():
	get_tree().quit()
"

[sub_resource type="StyleBoxFlat" id="StyleBoxFlat_k5okt"]
