[sub_resource type="GDScript" id="GDScript_jwk3o"]
script/source = "extends LineEdit

# Adjusted paths based on your scene structure
@onready var xTendMenuControl = get_node(\"/root/FullUI/MenuSystem/ExtendedMenu\")
@onready var mainMenuControl = get_node(\"/root/FullUI/MenuSystem/MainMenu\")
@onready var console = get_node(\"/root/FullUI/MenuSystem/MainMenu/VBoxContainer/ExtendedMenuInitiator/Console\")




func _on_text_submitted(new_text: String):
	console.visible = false
	if new_text ==  \"admin\":
		mainMenuControl.visible = false
		xTendMenuControl.visible = true
		text = str(\"\")
	else:
		console.visible = true
		console.text = \"Command '\" + new_text + \"' Not Found\"
		text = str(\"\")

"

